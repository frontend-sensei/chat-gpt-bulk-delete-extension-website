<section id="features" class="border-y border-violet/8 bg-white/55 py-24 sm:py-28">
  <div class="page-shell">
    <h2 class="section-heading">{{ locale.featuresHeading }}</h2>
    <div class="mt-14 grid gap-x-10 gap-y-12 md:grid-cols-2">
      {% for feature in locale.features %}
        <article class="grid grid-cols-[auto_1fr] gap-5">
          <div class="flex size-12 items-center justify-center rounded-2xl bg-gradient-to-br from-violet/15 to-mint/20 text-violet">
            {% if feature.icon == "checks" %}
              <svg class="size-6" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m4 7 2.5 2.5L11 5M4 16l2.5 2.5L11 14m3-6h6m-6 9h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {% elif feature.icon == "select-all" %}
              <svg class="size-6" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="5" y="5" width="14" height="14" rx="3" stroke="currentColor" stroke-width="2"/><path d="m8.5 12 2.2 2.2 4.8-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {% elif feature.icon == "confirm" %}
              <svg class="size-6" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3 4.5 6v5.2c0 4.5 3 7.8 7.5 9.8 4.5-2 7.5-5.3 7.5-9.8V6L12 3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="m8.5 12 2.2 2.2 4.8-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {% else %}
              <svg class="size-6" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M13 2 5 14h6l-1 8 8-12h-6l1-8Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
            {% endif %}
          </div>
          <div>
            <h3 class="text-xl font-bold tracking-[-0.025em]">{{ feature.title }}</h3>
            <p class="mt-3 max-w-lg leading-7 text-muted">{{ feature.text }}</p>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
