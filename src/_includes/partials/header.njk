<header class="page-shell flex items-center justify-between py-5 sm:py-7">
  <a class="flex items-center gap-3 rounded-xl" href="{{ locale.path }}" aria-label="{{ site.name }}">
    <img class="size-10 rounded-xl shadow-sm" src="/assets/icon.png" width="40" height="40" alt="">
    <span class="hidden text-sm font-bold tracking-[-0.02em] sm:inline">{{ site.name }}</span>
  </a>
  <nav class="flex items-center gap-2 sm:gap-5" aria-label="Primary">
    <a class="hidden rounded-lg px-2 py-2 text-sm font-semibold text-muted transition hover:text-ink md:inline" href="#features">{{ locale.nav.features }}</a>
    <a class="hidden rounded-lg px-2 py-2 text-sm font-semibold text-muted transition hover:text-ink md:inline" href="#privacy">{{ locale.nav.privacy }}</a>
    <details class="group relative">
      <summary class="flex cursor-pointer list-none items-center gap-2 rounded-xl border border-violet/15 bg-white/70 px-3 py-2 text-sm font-semibold shadow-sm transition hover:border-violet/30">
        <span aria-hidden="true">🌐</span>
        <span>{{ locale.languageName }}</span>
        <svg class="size-4 transition group-open:rotate-180" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="m6 8 4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </summary>
      <div class="absolute right-0 z-20 mt-2 min-w-36 rounded-2xl border border-violet/10 bg-white p-2 shadow-xl">
        {% for language in locales %}
          <a class="block rounded-xl px-3 py-2 text-sm font-semibold transition hover:bg-violet/8{% if language.locale == locale.locale %} bg-violet/8 text-violet{% endif %}" href="{{ language.path }}" lang="{{ language.locale }}" hreflang="{{ language.locale }}">
            {{ language.languageName }}
          </a>
        {% endfor %}
      </div>
    </details>
    <a class="primary-button hidden sm:inline-flex" href="{{ site.storeUrl }}" target="_blank" rel="noopener noreferrer">
      {{ locale.nav.install }}
    </a>
  </nav>
</header>
