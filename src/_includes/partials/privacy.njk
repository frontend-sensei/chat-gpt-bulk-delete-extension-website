<section id="privacy" class="page-shell py-24 sm:py-32">
  <div class="relative overflow-hidden rounded-[2rem] bg-ink px-6 py-12 text-white sm:px-12 sm:py-16 lg:px-16">
    <div class="absolute -top-28 right-0 size-80 rounded-full bg-violet/50 blur-3xl" aria-hidden="true"></div>
    <div class="absolute -bottom-40 left-1/3 size-72 rounded-full bg-mint/20 blur-3xl" aria-hidden="true"></div>
    <div class="relative grid items-center gap-9 lg:grid-cols-[1fr_auto]">
      <div class="max-w-3xl">
        <div class="flex size-12 items-center justify-center rounded-2xl bg-white/10 text-mint">
          <svg class="size-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 3 4.5 6v5.2c0 4.5 3 7.8 7.5 9.8 4.5-2 7.5-5.3 7.5-9.8V6L12 3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
            <path d="M9.5 12.5 11 14l3.8-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h2 class="mt-7 text-3xl font-bold tracking-[-0.04em] sm:text-4xl">{{ locale.privacy.title }}</h2>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-white/70">{{ locale.privacy.text }}</p>
      </div>
      <a class="inline-flex min-h-12 items-center justify-center rounded-2xl bg-white px-5 py-3 text-center text-sm font-bold text-ink transition hover:-translate-y-0.5 hover:bg-mint" href="{{ site.storeUrl }}" target="_blank" rel="noopener noreferrer">
        {{ locale.privacy.linkLabel }}
      </a>
    </div>
  </div>
</section>
