<footer class="border-t border-violet/10 bg-white/55">
  <div class="page-shell grid gap-8 py-10 sm:grid-cols-[1fr_auto] sm:items-end">
    <div>
      <div class="flex items-center gap-3">
        <img class="size-9 rounded-xl" src="/assets/icon.png" width="36" height="36" alt="">
        <span class="text-sm font-bold">{{ site.name }}</span>
      </div>
      <p class="mt-4 text-sm text-muted">{{ locale.footer.tagline }}</p>
      <p class="mt-2 max-w-xl text-xs leading-5 text-muted/80">{{ locale.footer.disclaimer }}</p>
    </div>
    <nav class="flex flex-wrap gap-2" aria-label="{{ locale.nav.language }}">
      {% for language in locales %}
        <a class="rounded-xl px-3 py-2 text-sm font-semibold transition hover:bg-violet/8{% if language.locale == locale.locale %} bg-violet/8 text-violet{% else %} text-muted{% endif %}" href="{{ language.path }}" lang="{{ language.locale }}" hreflang="{{ language.locale }}">
          {{ language.languageName }}
        </a>
      {% endfor %}
    </nav>
  </div>
</footer>
