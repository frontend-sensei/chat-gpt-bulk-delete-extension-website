{
  "name": "chat-gpt-bulk-delete-extension-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "clean": "rimraf dist .cache",
    "assets": "node scripts/build-assets.ts",
    "styles": "tailwindcss -i ./src/styles/input.css -o ./.cache/assets/styles.css --minify",
    "styles:watch": "npm run styles -- --watch",
    "eleventy": "eleventy --config=eleventy.config.ts",
    "eleventy:serve": "npm run assets && eleventy --config=eleventy.config.ts --serve",
    "build": "npm run clean && npm run assets && npm run styles && npm run eleventy",
    "build:production": "node scripts/validate-production-env.ts && npm run build",
    "dev": "npm run clean && npm run assets && concurrently -k \"npm:styles:watch\" \"npm:eleventy:serve\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:build": "SITE_URL=https://example.test npm run build && vitest run tests/build",
    "validate:html": "html-validate \"dist/**/*.html\"",
    "check": "npm run typecheck && npm run test && npm run test:build && npm run validate:html"
  },
  "dependencies": {
    "@11ty/eleventy": "3.1.6",
    "html-minifier-terser": "7.2.0",
    "nunjucks": "3.2.4",
    "sharp": "0.34.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.3.0",
    "@types/node": "24.10.1",
    "@types/nunjucks": "3.2.6",
    "cheerio": "1.2.0",
    "concurrently": "10.0.3",
    "html-validate": "11.5.2",
    "rimraf": "6.1.3",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
